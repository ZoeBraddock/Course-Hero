{
 "$schema": "https://json.schemastore.org/claude-code-settings.json",
 "model": "opus",
 "theme": "dark",
  "permissions": {
    "defaultMode": "plan",
    "deny": [
    "Read(//**/.*env)",
    "Bash(rm*)",
    "Bash(curl*)",
    "Bash(wget*)",
    "Bash(git push*)",
    "Bash(git * main)",
    "Edit(//**/.claude/settings.json)"
    ]
  }
}
